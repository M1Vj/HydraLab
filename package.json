{
  "name": "hydra",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter @hydra/web dev",
    "build": "bun run --filter @hydra/web build",
