{
  "manifest_version": 3,
  "name": "HydraLab Browser Bridge",
  "description": "Save active research pages and selections to the local HydraLab project after explicit permission.",
  "version": "0.1.0",
  "action": {
    "default_title": "Save to HydraLab",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "host_permissions": ["http://127.0.0.1/*"]
}
